# Optional: copy this file to .env and set your values.
# Windows: start.bat loads .env after activating the virtual environment.
# Mac/Unix: start.sh sources .env after activating the virtual environment.
# Lines starting with # are ignored.

# AWS profile for Bedrock and other AWS SDK calls (e.g. after "aws sso login")
AWS_PROFILE=your-profile-name
AWS_DEFAULT_PROFILE=your-profile-name
